{
  "name": "open-upsp",
  "version": "0.3.5",
  "description": "Universal Persona Substrate Protocol — lightweight persona management with Zettelkasten integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "open-upsp": "dist/cli.js",
    "upsp": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts",
    "skill",
    "vendor"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "persona",
    "upsp",
    "zettelkasten",
    "ai-memory",
    "context-management"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^13.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^3.2.7",
    "typescript": "^5.8.0",
    "vitest": "^3.2.7"
  }
}
